@startuml
title 第 7 章功能架构图：具身智能里的 Agentic AI 能力与组成
top to bottom direction
skinparam shadowing false
skinparam linetype ortho
skinparam defaultTextAlignment center
skinparam dpi 180
skinparam nodesep 26
skinparam ranksep 28
skinparam BackgroundColor #FFFFFF
skinparam packageStyle rectangle
skinparam package {
  BorderColor #A6A6A6
  BackgroundColor #D3D3D3
  FontColor #111111
  FontSize 18
  RoundCorner 10
}
skinparam package<<whitebox>> {
  BorderColor #A6A6A6
  BackgroundColor #FFFFFF
  FontColor #111111
  FontSize 16
  RoundCorner 8
}
skinparam rectangle {
  BorderColor #8E8E8E
  BackgroundColor #FFFFFF
  FontColor #111111
  FontSize 15
  RoundCorner 8
}

package "HMI / 工单" as HMI {
  rectangle "调度" as HMI_SCHED
  rectangle "工单" as HMI_WORK
  rectangle "API" as HMI_API
  rectangle "Voice" as HMI_VOICE

  HMI_SCHED -[hidden]right-> HMI_WORK
  HMI_WORK -[hidden]right-> HMI_API
  HMI_API -[hidden]right-> HMI_VOICE
}

package "领域技能" as DOMAIN {
  rectangle "领域定义" as DOMAIN_DEF
  rectangle "领域技能" as DOMAIN_SKILL

  DOMAIN_DEF -[hidden]down-> DOMAIN_SKILL
}

package "智能体核心" as AGENT {
  rectangle "任务理解" as AGENT_TASK
  rectangle "长程规划" as AGENT_PLAN
  rectangle "状态判断" as AGENT_STATE
  rectangle "后续决策" as AGENT_DECIDE

  AGENT_TASK -[hidden]right-> AGENT_PLAN
  AGENT_PLAN -[hidden]right-> AGENT_STATE
  AGENT_STATE -[hidden]right-> AGENT_DECIDE
}

package "状态/记忆/知识" as MEMORY {
  rectangle "状态快照" as MEM_SNAPSHOT
  rectangle "历史案例" as MEM_CASE
  rectangle "日志回放" as MEM_REPLAY
  rectangle "工艺配方" as MEM_RECIPE
  rectangle "产品配置" as MEM_PRODUCT

  MEM_SNAPSHOT -[hidden]down-> MEM_CASE
  MEM_CASE -[hidden]down-> MEM_REPLAY
  MEM_REPLAY -[hidden]down-> MEM_RECIPE
  MEM_RECIPE -[hidden]down-> MEM_PRODUCT
}

package "技能智能编排" as ORCH {
  rectangle "技能选择" as ORCH_SELECT
  rectangle "参数补全" as ORCH_PARAM
  rectangle "行为规划" as ORCH_PLAN
  rectangle "约束检查" as ORCH_GUARD

  ORCH_SELECT -[hidden]right-> ORCH_PARAM
  ORCH_PARAM -[hidden]right-> ORCH_PLAN
  ORCH_PLAN -[hidden]right-> ORCH_GUARD
}

package "感知/推理" as REASON {
  rectangle "世界模型" as REASON_WORLD
  rectangle "空间智能" as REASON_SPATIAL
  rectangle "视觉模型" as REASON_VISION

  REASON_WORLD -[hidden]down-> REASON_SPATIAL
  REASON_SPATIAL -[hidden]down-> REASON_VISION
}

package "技能运行时" as RUNTIME {
  rectangle "技能映射" as RUN_MAP
  rectangle "参数绑定" as RUN_BIND
  rectangle "约束检查" as RUN_CHECK
  rectangle "执行调度" as RUN_SCHEDULE

  package "Robot Adapter" <<whitebox>> as ADAPTER {
    rectangle "ABB" as ADAPTER_ABB
    rectangle "ROS2" as ADAPTER_ROS2
    rectangle "Vision" as ADAPTER_VISION
    rectangle "PLC" as ADAPTER_PLC

    ADAPTER_ABB -[hidden]right-> ADAPTER_ROS2
    ADAPTER_ROS2 -[hidden]right-> ADAPTER_VISION
    ADAPTER_VISION -[hidden]right-> ADAPTER_PLC
  }

  RUN_MAP -[hidden]right-> RUN_BIND
  RUN_BIND -[hidden]right-> RUN_CHECK
  RUN_CHECK -[hidden]right-> RUN_SCHEDULE
  RUN_MAP -[hidden]down-> ADAPTER
}

package "控制器" as CTRL {
  rectangle "ABB Ctrl" as CTRL_ABB
  rectangle "RAPID" as CTRL_RAPID
  rectangle "ROS2" as CTRL_ROS2

  CTRL_ABB -[hidden]right-> CTRL_RAPID
  CTRL_RAPID -[hidden]right-> CTRL_ROS2
}

package "现场设备" as DEVICE {
  rectangle "机械臂" as DEV_ARM
  rectangle "末端工具" as DEV_TOOL
  rectangle "PLC" as DEV_PLC

  DEV_ARM -[hidden]right-> DEV_TOOL
  DEV_TOOL -[hidden]right-> DEV_PLC
}

HMI -[hidden]right-> DOMAIN
AGENT -[hidden]right-> MEMORY
ORCH -[hidden]right-> REASON
CTRL -[hidden]right-> DEVICE

HMI -[hidden]down-> AGENT
DOMAIN -[hidden]down-> MEMORY
AGENT -[hidden]down-> ORCH
MEMORY -[hidden]down-> REASON
ORCH -[hidden]down-> RUNTIME
RUNTIME -[hidden]down-> CTRL
REASON -[hidden]down-> DEVICE
@enduml
